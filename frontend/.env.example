# Frontend environment template.
# Copy to frontend/.env for local development.
# React requires variables exposed to the browser to start with REACT_APP_.
# Do not put secrets in frontend env vars.

PORT=3001
REACT_APP_API_URL=http://localhost:3030

REACT_APP_BILLING_IBAN=replace-with-billing-iban
REACT_APP_BILLING_BENEFICIARY=replace-with-billing-beneficiary
REACT_APP_BILLING_BANK=replace-with-billing-bank
