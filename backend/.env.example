# Backend environment template.
# Copy to backend/.env for local development.
# Do not commit real secrets.

NODE_ENV=development
PORT=3030

# Required for OCR and persistence.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODEL=gpt-5.5
MONGODB_URI=mongodb://127.0.0.1:27017/ocr-finance

# Required in production. Use a strong random value, at least 32 characters.
AUTH_SECRET=replace-with-strong-random-secret-at-least-32-chars
AUTH_TOKEN_TTL_SECONDS=43200

# Comma-separated browser origins allowed to call the API.
# Required in production.
CORS_ORIGINS=http://localhost:3001
ADMIN_EMAILS=

# Local/private storage.
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
STORAGE_BACKEND=local
LOCAL_UPLOAD_RETENTION_DAYS=30
LOCAL_OUTPUT_RETENTION_DAYS=7
LOCAL_STORAGE_CLEANUP_INTERVAL_MS=21600000

# PDF/OCR processing guardrails.
PYTHON_COMMAND=py
PDF_RENDER_DPI=200
PDF_MAX_PAGES=5
PDF_CONVERSION_TIMEOUT_MS=30000
OCR_REQUEST_TIMEOUT_MS=60000
OCR_MAX_CONCURRENT_JOBS=2

# Rate limits.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000
UPLOAD_RATE_LIMIT_MAX=30
EXTRACT_RATE_LIMIT_WINDOW_MS=3600000
EXTRACT_RATE_LIMIT_MAX=10
EXPORT_RATE_LIMIT_WINDOW_MS=3600000
EXPORT_RATE_LIMIT_MAX=60

# Malware scanning is required in production.
MALWARE_SCAN_COMMAND=
MALWARE_SCAN_ARGS=
MALWARE_SCAN_TIMEOUT_MS=30000

# Optional PDF fonts for Cyrillic output.
PDF_FONT_REGULAR_PATH=
PDF_FONT_BOLD_PATH=
