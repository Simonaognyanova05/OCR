# Optional shared backend environment.
# Backend loads backend/.env first, then this root .env without overriding existing values.
# Prefer backend/.env for local backend settings and frontend/.env for React settings.

NODE_ENV=development
OPENAI_API_KEY=replace-with-openai-api-key
MONGODB_URI=mongodb://127.0.0.1:27017/ocr-finance
AUTH_SECRET=replace-with-strong-random-secret-at-least-32-chars
CORS_ORIGINS=http://localhost:3001
